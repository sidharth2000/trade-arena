server:
  port: 8080

spring:
  application:
    name: api-gateway

  cloud:
    gateway:
      routes:
        - id: auth-service
          uri: http://localhost:8081
          predicates:
            - Path=/auth/**

        - id: admin-service
          uri: http://localhost:8082
          predicates:
            - Path=/admin/**

app:
  jwt:
    secret: your-256-bit-secret-key-same-as-auth-service

eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka
    register-with-eureka: true
    fetch-registry: true